services:
  my_service:           # name you make up — used in exec/logs commands
    image: ubuntu:22.04 # use a pre-built image...
    build: .            # ...OR build from a local Dockerfile (can use both)
    container_name: my_container
    restart: unless-stopped   # auto-restart policy
    ports:
      - "8080:80"       # host:container port mapping
    volumes:
      - ./local:/container    # bind mount (syncs local folder)
      - mydata:/data          # named volume (managed by Docker)
    environment:
      - MY_VAR=hello
    depends_on:
      - database        # start this service first
    networks:
      - mynet

  database:
    image: postgres:15
    environment:
      - POSTGRES_PASSWORD=secret
    volumes:
      - pgdata:/var/lib/postgresql/data

volumes:
  mydata:
  pgdata: